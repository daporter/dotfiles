#!/bin/bash

# compress_pdf: run PDFs through `ocrmypdf`, writing the result alongside each
# input as `<name>-compressed.pdf`. Output is only written if there is meaningful
# space savings, or if the input's text layer looks missing or bad (in which case
# a contemporary tesseract run will be useful).
#
# The input file is never modified, and an existing output file is never
# overwritten. Output is only written if ocrmypdf reported success on it and it
# still parses as a PDF.

set -euo pipefail

MIN_RATIO=${COMPRESS_PDF_MIN_RATIO:-1.5}       # write the output only if it is at least this many times smaller
MIN_WORDS=${COMPRESS_PDF_MIN_WORDS:-50}        # fewer words per page than this means the text layer is missing or bad
MIN_BYTES=${COMPRESS_PDF_MIN_BYTES:-4096}      # output smaller than this is a failed ocrmypdf run, not a small PDF
SUFFIX=${COMPRESS_PDF_SUFFIX:--compressed}     # `foo.pdf` becomes `foo-compressed.pdf`

# `--optimize 3` still does lossless JBIG2. Do not add `--jbig2-lossy`: ocrmypdf
# ignores it as of v17, having removed lossy JBIG2 for substituting matching
# glyphs and thereby silently swapping similar-looking characters.
OCR_OPTS=(--optimize 3)

# Working files for the PDF being processed. Global so the EXIT trap can reach
# them; compress() gives each file a fresh set. There is no temporary copy of the
# input: ocrmypdf does not modify what it reads.
candidate_pdf=''  # ocrmypdf's output, kept only once it has earned its place
ocr_log=''

# Tallied by compress(), reported by main().
written=0 unchanged=0 failed=0

cleanup() { rm -f "$candidate_pdf" "$ocr_log"; }
trap cleanup EXIT

# Progress goes to stderr, so that it stays visible when stdout is redirected and
# never gets mistaken for output. Steps are indented under the file they concern.
heading() { printf '\n%s\n' "$*" >&2; }
step() { printf '  %s\n' "$*" >&2; }
warn() { printf '  ! %s\n' "$*" >&2; }
die() { printf '%s: %s\n' "${0##*/}" "$*" >&2; exit 1; }

file_size() { stat --format=%s "$1"; }
human_size() { numfmt --to=iec "$1"; }
word_count() { pdftotext "$1" - | wc --words; }
# shellcheck disable=SC2016  # $PageCount is exiftool's format syntax, not a shell variable
page_count() { exiftool -quiet -printFormat '$PageCount' -PageCount "$1"; }

# Where the compressed version of $1 belongs: `a/b/foo.pdf` -> `a/b/foo-compressed.pdf`.
output_path() {
    local without_extension=${1%.[Pp][Dd][Ff]}
    printf '%s%s.pdf\n' "$without_extension" "$SUFFIX"
}

# Floating-point `>`, which bash arithmetic cannot do.
greater_than() { (( $(echo "$1 > $2" | bc --mathlib) )); }

# Run ocrmypdf quietly, but surface its diagnostics when it fails.
run_ocrmypdf() {
    if ! ocrmypdf "$@" &>"$ocr_log"; then
        warn "ocrmypdf failed:"
        sed 's/^/    /' "$ocr_log" >&2
        return 1
    fi
}

# Did ocrmypdf leave us a real PDF, rather than a truncated or empty file?
is_valid_pdf() {
    (( $(file_size "$1") >= MIN_BYTES )) && pdftotext "$1" - &>/dev/null
}

# Publish NEW as DEST, restoring from SOURCE the metadata that ocrmypdf and
# Ghostscript erase by default:
# <https://ocrmypdf.readthedocs.io/en/latest/introduction.html#limitations>
# DEST inherits SOURCE's permissions rather than mktemp's restrictive 0600.
write_output() {
    local source=$1 new=$2 dest=$3
    exiftool -quiet -overwrite_original -TagsFromFile "$source" "$new" || warn "could not restore metadata"
    cat "$new" >"$dest"
    chmod --reference="$source" "$dest"
}

# Give up on this file, having written nothing.
give_up() {
    warn "$*"
    step "writing no output"
    failed=$((failed + 1))
}

compress() {
    local file=$1 dest=$2 before after ratio pages words started

    candidate_pdf=$(mktemp /tmp/XXXXXX-candidate.pdf)
    ocr_log=$(mktemp /tmp/XXXXXX-ocrmypdf.log)

    # 1. Optimize, leaving any existing text layer alone.
    step "optimizing (this can take a while)..."
    started=$SECONDS
    run_ocrmypdf --skip-text "${OCR_OPTS[@]}" "$file" "$candidate_pdf" \
        || { give_up "ocrmypdf could not optimize it"; return; }
    is_valid_pdf "$candidate_pdf" \
        || { give_up "the optimized output is not a usable PDF"; return; }

    before=$(file_size "$file")
    after=$(file_size "$candidate_pdf")
    ratio=$(printf '%.2f' "$(echo "$before / $after" | bc --mathlib)")
    step "$(human_size "$before") → $(human_size "$after") (${ratio}x) in $((SECONDS - started))s"

    if greater_than "$ratio" "$MIN_RATIO"; then
        write_output "$file" "$candidate_pdf" "$dest"
        step "wrote $dest, saving $(human_size $((before - after)))"
        written=$((written + 1))
        return
    fi

    # 2. Optimizing did not pay off, but the PDF may still want OCR: force it on
    #    PDFs with no text layer, or a suspiciously thin one. (`--force-ocr`
    #    rasterizes the page and discards any text already there; `--redo-ocr` is
    #    the gentler alternative.)
    step "under the ${MIN_RATIO}x threshold: checking the text layer instead"
    pages=$(page_count "$file" || true)
    if ! [[ $pages =~ ^[0-9]+$ ]] || (( pages == 0 )); then
        give_up "cannot read a page count"
        return
    fi
    words=$(word_count "$file") || { give_up "cannot extract any text"; return; }
    step "$words words across $pages pages"

    if (( words >= MIN_WORDS * pages )); then
        step "nothing to gain: writing nothing"
        unchanged=$((unchanged + 1))
        return
    fi

    step "under $MIN_WORDS words/page: forcing OCR (this can take a while)..."
    started=$SECONDS
    run_ocrmypdf --force-ocr "${OCR_OPTS[@]}" "$file" "$candidate_pdf" \
        || { give_up "ocrmypdf could not OCR it"; return; }
    is_valid_pdf "$candidate_pdf" \
        || { give_up "the forced-OCR output is not a usable PDF"; return; }

    step "OCR'd in $((SECONDS - started))s"
    write_output "$file" "$candidate_pdf" "$dest"
    step "wrote $dest ($(human_size "$(file_size "$dest")"))"
    written=$((written + 1))
}

main() {
    local cmd file dest n=0

    (( $# > 0 )) || die "usage: ${0##*/} FILE.pdf [FILE.pdf ...]"
    for cmd in ocrmypdf exiftool pdftotext bc numfmt; do
        command -v "$cmd" &>/dev/null || die "missing dependency: $cmd"
    done
    for file in "$@"; do
        [[ -f $file ]] || die "not a file: $file"
        [[ $(output_path "$file") != "$file" ]] || die "empty suffix would overwrite $file"
    done

    for file in "$@"; do
        n=$((n + 1))
        dest=$(output_path "$file")
        heading "[$n/$#] $file ($(human_size "$(file_size "$file")"))"

        if [[ -e $dest ]]; then
            warn "$dest already exists; remove it to re-run"
            failed=$((failed + 1))
            continue
        fi

        compress "$file" "$dest"
        cleanup
    done

    heading "$# file(s): $written written, $unchanged unchanged, $failed failed"
    (( failed == 0 ))
}

main "$@"
